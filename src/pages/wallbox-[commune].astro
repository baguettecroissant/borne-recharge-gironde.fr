---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CityMap from '../components/CityMap.astro';
import communes from '../data/communes.json';
import config from '../data/config.json';
import { getSmartNearbyCommunes } from '../lib/geoLinks';
import { generateCommuneContent, getDynamicPrices, getClimateZone } from '../lib/contentEngine';

export async function getStaticPaths() {
  return communes.map((commune) => {
    return {
      params: { commune: commune.slug },
      props: { commune },
    };
  });
}

const { commune } = Astro.props;

const title = `Achat et Pose de Wallbox à ${commune.nom} (${commune.codePostal}) — Comparatif & Devis`;
const description = `Quelle Wallbox installer chez vous à ${commune.nom} ? Comparatif des puissances (7.4kW, 11kW, 22kW) et des marques leaders. Devis gratuit IRVE.`;

const prices = getDynamicPrices(commune);
const isZFE = getClimateZone(commune.codePostal, commune.slug) === 'bordeaux-metropole';

// Spun content for wallbox category
const content = generateCommuneContent(commune, 'wallbox');

// Proximity communes
const nearby = getSmartNearbyCommunes(commune.slug, communes, 5, 2);

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes (33)", href: "/communes/" },
  { label: `Wallbox ${commune.nom}` }
];

function getLocalAgencyInfo(codePostal: string, slug: string) {
  const zone = getClimateZone(codePostal, slug);
  if (zone === 'bordeaux-metropole') {
    return {
      name: "l'ALEC de la Métropole de Bordeaux",
      website: "alec-mb33.fr"
    };
  }
  return {
    name: "l'Espace Conseil France Rénov' de Gironde",
    website: "creaq.org"
  };
}
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={content.faqItems}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
  />

  <!-- Hero with wallbox parameters -->
  <Hero communeName={commune.nom} categoryName="Wallbox" />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Main Grid Layout -->
  <section class="static-page-section" style="background-color: var(--bg); padding: 50px 0 80px;">
    <div class="container two-column-layout">
      <!-- Main Content Column -->
      <div class="static-main-content" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
        
        <!-- Smart Charging Alert -->
        <div style={`margin-bottom: 30px; padding: 20px; border-radius: var(--radius-sm); border: 1px solid var(--accent); background-color: var(--primary-light); display: flex; align-items: center; gap: 15px;`}>
          <div style="font-size: 28px;">⚡</div>
          <div>
            <h4 style="font-size: 15px; color: var(--primary); font-weight: bold; margin: 0;">
              Bornes Connectées & Délestage Linky — {commune.nom}
            </h4>
            <p style="font-size: 13.5px; margin: 4px 0 0; color: var(--text-muted);">
              Toutes les wallbox posées par nos techniciens intègrent un module de délestage dynamique TIC ou un capteur de puissance. La charge s'adapte en temps réel pour protéger votre installation électrique.
            </p>
          </div>
        </div>

        <p class="lead" style="font-size: 17px; font-weight: 700; color: var(--primary); line-height: 1.6; margin-bottom: 25px;">
          {content.introParagraph}
        </p>

        <h2>📊 Quelle marque de Wallbox choisir à {commune.nom} ?</h2>
        <p>
          Pour charger votre véhicule électrique (Tesla, Peugeot e-208, Renault Megane E-Tech, etc.) en toute sérénité à <strong>{commune.nom}</strong>, nos installateurs ont sélectionné les 5 modèles leaders du marché en 2026 :
        </p>

        <div style="display: flex; flex-direction: column; gap: 20px; margin: 25px 0;">
          <div style="background: var(--bg); padding: 20px; border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
            <h4 style="font-size: 16px; color: var(--primary); font-weight: bold; margin-bottom: 6px;">1. Legrand Green'Up Premium</h4>
            <p style="font-size: 13.5px; margin: 0; color: var(--text-muted);">Le savoir-faire français historique. Une borne extrêmement robuste, certifiée IP55 et IK08, idéale pour une installation dans un garage ou en extérieur. Très compatible avec les architectures électriques françaises.</p>
          </div>
          <div style="background: var(--bg); padding: 20px; border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
            <h4 style="font-size: 16px; color: var(--primary); font-weight: bold; margin-bottom: 6px;">2. Hager Witty</h4>
            <p style="font-size: 13.5px; margin: 0; color: var(--text-muted);">Le choix privilégié des électriciens. La borne Hager Witty intègre nativement des protections différentielles et de délestage ultra-fiables. Elle est réputée pour sa longévité et sa sécurité électrique sans faille.</p>
          </div>
          <div style="background: var(--bg); padding: 20px; border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
            <h4 style="font-size: 16px; color: var(--primary); font-weight: bold; margin-bottom: 6px;">3. Wallbox Pulsar Plus / Max</h4>
            <p style="font-size: 13.5px; margin: 0; color: var(--text-muted);">Compacte et connectée. Elle offre une application mobile performante pour programmer vos charges en heures creuses, suivre vos consommations en direct et verrouiller la borne à distance via Bluetooth ou Wi-Fi.</p>
          </div>
          <div style="background: var(--bg); padding: 20px; border-radius: var(--radius-sm); border: 1px solid var(--border-color);">
            <h4 style="font-size: 16px; color: var(--primary); font-weight: bold; margin-bottom: 6px;">4. Easee One</h4>
            <p style="font-size: 13.5px; margin: 0; color: var(--text-muted);">Design scandinave et évolutif. Ce boîtier compact dispose d'une gestion intelligente de la puissance pour les foyers prévoyant d'équiper plusieurs places à terme (partage de puissance automatique sans surcharger l'abonnement Enedis).</p>
          </div>
        </div>

        <h2>💰 Amortissement & Avantages Économiques de la Wallbox</h2>
        <p>{content.ecoText}</p>
        <p>
          L'installation d'une borne intelligente vous permet de diviser par 5 le coût de votre "plein" électrique à {commune.nom} par rapport aux carburants traditionnels. De plus, charger à domicile en heures creuses Enedis évite les tarifs prohibitifs appliqués sur les réseaux de charge publics de Gironde.
        </p>

        <!-- Technical Tips -->
        <h2>⚡ Conseil technique de l'électricien IRVE</h2>
        <div style="background: #fffbeb; border-left: 4px solid var(--accent); padding: 18px 24px; margin: 25px 0; border-radius: 0 var(--radius-sm) var(--radius-sm) 0;">
          <p style="font-style: italic; font-weight: 500; margin: 0; color: var(--text);">
            "{content.expertTip}"
          </p>
        </div>

        <p>{content.useCaseText}</p>
        <p>{content.communeDataInsight}</p>
        <p>{content.distanceLyonContext}</p>

        <!-- Données locales uniques -->
        <h2>🏡 Immobilier & Valeur verte Wallbox à {commune.nom}</h2>
        <p>{content.marcheImmobilierInsight}</p>
        <p>{content.realEstateInsight}</p>

        <h2>🚗 Électromobilité sur votre commune</h2>
        <p>{content.densiteAnalysis}</p>
        <p>{content.populationTierContent}</p>
        <p>{content.localRegulation}</p>

        <h2>📊 Quel budget pour l'achat et la pose d'une Wallbox à {commune.nom} ?</h2>
        <p>{content.tableIntro}</p>

        <div class="table-scroll-wrapper" style="margin: 25px 0;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Puissance de Charge</th>
                <th>Temps pour récupérer 100 km</th>
                <th>Intérêt / Compatibilité</th>
                <th>Tarif moyen posé</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Wallbox 7.4 kW (Monophasé)</strong></td>
                <td>~1h45 de charge</td>
                <td>Standard absolu pour maison individuelle (compteur Linky de 9kVA+)</td>
                <td class="price">{prices.wallbox7kW.min}€ – {prices.wallbox7kW.max}€</td>
              </tr>
              <tr>
                <td><strong>Wallbox 11 kW (Triphasé)</strong></td>
                <td>~1h15 de charge</td>
                <td>Idéal pour véhicules à grosse batterie avec compteur triphasé</td>
                <td class="price">{prices.wallbox11kW.min}€ – {prices.wallbox11kW.max}€</td>
              </tr>
              <tr>
                <td><strong>Wallbox 22 kW (Triphasé)</strong></td>
                <td>~35 minutes de charge</td>
                <td>Recharge ultra-rapide (nécessite chargeur embarqué de 22kW type Zoé)</td>
                <td class="price">{prices.wallbox22kW.min}€ – {prices.wallbox22kW.max}€</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p style="font-size: 12.5px; color: var(--text-muted); font-style: italic;">
          * {content.sourcesCitation}. Le prix du matériel inclut les modules de protection différentielle obligatoire (type A-EV) imposés par la norme NF C 15-100 pour prévenir tout risque d'électrocution.
        </p>

        <!-- Local Map -->
        <h2>📍 Installation locale et carte d'intervention à {commune.nom}</h2>
        <p>Nos artisans qualifiés IRVE se déplacent pour auditer votre tableau électrique et poser votre wallbox dans toute la commune de <strong>{commune.nom}</strong> :</p>
        <CityMap cityName={commune.nom} zip={commune.codePostal} />

        <!-- FAQ Accordion -->
        <h2 style="margin-top: 40px;">❓ Questions Fréquentes — Choix & Installation de Wallbox</h2>
        <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 20px;">
          {content.faqItems.map(faq => (
            <details class="faq-details">
              <summary>
                {faq.question}
              </summary>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <!-- Cross-Template Internal Links (même commune) -->
        <div style="margin-top: 50px; padding-top: 30px; border-top: 1px solid var(--border-color);">
          <h4 style="font-size: 15px; color: var(--primary); margin-bottom: 15px; font-weight: bold;">📌 Toutes nos prestations à {commune.nom} :</h4>
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 25px;">
            <a href={`/installateur-borne-recharge-${commune.slug}/`} style="font-size: 13px; background: var(--bg); border: 1px solid var(--border-color); padding: 8px 14px; border-radius: 4px; color: var(--primary); font-weight: bold;">
              🔌 Installateur IRVE {commune.nom}
            </a>
            <a href={`/borne-recharge-copropriete-${commune.slug}/`} style="font-size: 13px; background: var(--bg); border: 1px solid var(--border-color); padding: 8px 14px; border-radius: 4px; color: var(--primary); font-weight: bold;">
              🏢 Copropriété {commune.nom}
            </a>
            <a href={`/wallbox-${commune.slug}/`} style="font-size: 13px; background: var(--primary); color: white; padding: 8px 14px; border-radius: 4px; font-weight: bold;" aria-current="page">
              ⚡ Wallbox {commune.nom}
            </a>
          </div>

          <h4 style="font-size: 15px; color: var(--primary); margin-bottom: 12px; font-weight: bold;">🗺️ Installation de Wallbox dans les communes proches :</h4>
          <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 15px;">
            {nearby.map(c => (
              <a href={`/wallbox-${c.slug}/`} style="font-size: 12.5px; background: var(--bg); border: 1px solid var(--border-color); padding: 5px 10px; border-radius: 4px; color: var(--primary); font-weight: bold;">
                {c.nom} ({c.codePostal})
              </a>
            ))}
          </div>

          <details style="margin-top: 10px;">
            <summary style="cursor: pointer; font-size: 13px; font-weight: 700; color: var(--accent);">
              Voir aussi : Installateur IRVE & Copropriété dans les villes proches →
            </summary>
            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px;">
              {nearby.map(c => (
                <a href={`/installateur-borne-recharge-${c.slug}/`} style="font-size: 11.5px; background: #eff6ff; border: 1px solid #dbeafe; padding: 4px 8px; border-radius: 3px; color: #1e40af;">
                  🔌 IRVE {c.nom}
                </a>
              ))}
              {nearby.map(c => (
                <a href={`/borne-recharge-copropriete-${c.slug}/`} style="font-size: 11.5px; background: #ecfdf5; border: 1px solid #d1fae5; padding: 4px 8px; border-radius: 3px; color: #065f46;">
                  🏢 Copro {c.nom}
                </a>
              ))}
            </div>
          </details>
        </div>

      </div>

      <!-- Sidebar Column -->
      <div class="static-sidebar">
        <!-- CTA widget -->
        <div class="sidebar-widget bg-purple-gradient">
          <h3 style="font-family: var(--font-heading); font-size: 18px; margin-bottom: 12px;">⚡ Choix Wallbox</h3>
          <p>
            Vous ne savez pas quelle borne est compatible avec votre abonnement Enedis ou votre véhicule à {commune.nom} ?
          </p>
          <a href="#devis" class="sidebar-cta-gold">
            Demander conseil &rarr;
          </a>
        </div>

        <!-- Local Agency info widget -->
        <div class="sidebar-widget">
          <h3>🏢 Accompagnement local</h3>
          <p>
            Pour valider vos dossiers de subventions locales ou obtenir un avis technique neutre sur l'isolation ou la transition énergétique de votre logement à {commune.nom}, contactez :
          </p>
          <p style="font-weight: 700; color: var(--primary); font-size: 14px; margin-bottom: 5px;">
            {content.localAgencyName}
          </p>
          <p style="font-size: 12.5px; line-height: 1.4; margin-bottom: 15px;">
            Organisme public de conseil en éco-habitat et transition écologique en Gironde.
          </p>
          <a href={`https://www.${getLocalAgencyInfo(commune.codePostal, commune.slug).website}`} target="_blank" rel="noopener noreferrer" style="font-size: 13px; font-weight: 700; color: var(--accent); text-decoration: underline;">
            Visiter leur site officiel &rarr;
          </a>
        </div>

        <!-- Guides Showcase widget -->
        <div class="sidebar-widget">
          <h3>📚 Guides utiles</h3>
          <div style="display: flex; flex-direction: column; gap: 12px;">
            {content.guideLinks.map(guide => (
              <a href={guide.href} style="display: block; text-decoration: none; color: inherit;">
                <h4 style="font-size: 14px; color: var(--primary); margin: 0 0 4px 0; font-weight: bold; text-decoration: underline;">{guide.label}</h4>
                <p style="font-size: 12px; color: var(--text-muted); margin: 0; line-height: 1.4;">{guide.desc}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
